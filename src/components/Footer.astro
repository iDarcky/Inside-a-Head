---
import Manifesto from './Manifesto.astro';

interface Props {
  className?: string;
  variant?: 'massive' | 'minimal';
}

const { className = "", variant = "minimal" } = Astro.props;
---

<footer class={`footer-base ${variant === 'massive' ? 'footer-massive' : 'footer-minimal'} ${className}`} id="social">
  {variant === 'massive' && (
    <div class="footer-huge-links">
      <a href="#" id="manifesto-btn" data-hover>MANIFESTO</a>
      <a href="https://github.com/iDarcky" target="_blank" rel="noreferrer" id="github-btn" data-hover>GITHUB</a>
      <a href="https://www.linkedin.com/in/danielnmaghis/" target="_blank" rel="noreferrer" id="linkedin-btn" data-hover>LINKEDIN</a>
      <a href="https://www.goodreads.com/user/show/106429003-daniel-maghis" target="_blank" rel="noreferrer" id="goodreads-btn" data-hover>GOODREADS</a>
      <a href="https://www.instagram.com/danielmhimself/" target="_blank" rel="noreferrer" id="instagram-btn" data-hover>INSTAGRAM</a>
    </div>
  )}
  <div class="footer-bottom-meta" style={variant === 'minimal' ? "border-top: none; padding-top: 1rem; padding-bottom: 2rem;" : ""}>
    <p>© 2026 INSIDE A HEAD STUDIO.</p>
    <a href="#top" class="back-to-top" data-hover>BACK TO TOP ↑</a>
  </div>
</footer>

<Manifesto />
