---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  backgroundColor?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  publishedAt?: string;
}

const { title, backgroundColor, description = "Inside a Head - Project Detail", ogImage, ogType = "article", publishedAt } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const socialImage = ogImage || new URL('/favicon.svg', Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title} | Inside a Head</title>

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    {publishedAt && <meta property="article:published_time" content={publishedAt} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />

    <!-- Lucide Icons -->
    <script is:inline src="https://unpkg.com/lucide@0.460.0"></script>

    <!-- GSAP & ScrollTrigger -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <ClientRouter />
  </head>
  <body id="top" class="magazine-layout page-wrapper" data-project-bg={backgroundColor} style={backgroundColor ? `background-color: ${backgroundColor};` : ''}>
    <div class="custom-cursor" transition:persist></div>
    
    <header class="project-header">
      <div class="header-inner">
        <a href="/" class="project-logo" data-hover>
          <span>INSIDE A HEAD</span>
          <span class="anchor-sub">STUDIO</span>
        </a>
        <nav class="nav-links">
          <a href="/" class="nav-link" data-hover>Studio</a>
          <a href="/projects" class="nav-link" data-hover>Projects</a>
          <a href="/logbook" class="nav-link" data-hover>Logbook</a>
          <a href="/museum" class="nav-link" data-hover>Museum</a>
          <a href="/about" class="nav-link" data-hover>About</a>
          <a href="/resume" class="nav-link" data-hover>Resume</a>
        </nav>
        <!-- Mobile Hamburger Button -->
        <button class="hamburger-btn" aria-label="Toggle menu">
          <div class="hamburger-box">
            <div class="hamburger-line"></div>
            <div class="hamburger-line"></div>
            <div class="hamburger-line"></div>
          </div>
        </button>
      </div>
    </header>

    <!-- Full-Screen Hamburger Menu Overlay -->
    <div class="mobile-menu-overlay">
      <nav class="mobile-nav-links">
        <a href="/" class="mobile-nav-link">Studio</a>
        <a href="/projects" class="mobile-nav-link">Projects</a>
        <a href="/logbook" class="mobile-nav-link">Logbook</a>
        <a href="/museum" class="mobile-nav-link">Museum</a>
        <a href="/about" class="mobile-nav-link">About</a>
        <a href="/resume" class="mobile-nav-link">Resume</a>
      </nav>
      <div class="mobile-menu-footer">
        <div class="mobile-socials">
          <a href="https://github.com/iDarcky" target="_blank" rel="noreferrer">GITHUB</a>
          <a href="https://www.linkedin.com/in/danielnmaghis/" target="_blank" rel="noreferrer">LINKEDIN</a>
        </div>
      </div>
    </div>

    <!-- The actual content injected here -->
    <slot />
    
    <Footer />

    <script is:inline src="/project.js"></script>
  </body>
</html>
