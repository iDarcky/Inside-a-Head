---
// src/layouts/MagazineLayout.astro

import '../styles/global.css';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  backgroundColor?: string;
}

const { title, backgroundColor } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Inside a Head</title>

    <!-- Lucide Icons -->
    <script is:inline src="https://unpkg.com/lucide@latest"></script>

    <!-- GSAP & ScrollTrigger -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <style>
      .resume-header {
        position: relative !important;
        background: var(--background) !important;
        border-bottom: 1px solid var(--accents-2) !important;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        mix-blend-mode: normal !important;
      }
      .resume-header .project-logo,
      .resume-header .nav-link {
        color: var(--foreground) !important;
      }
    </style>
  </head>
  <body id="top" class="magazine-layout page-wrapper" style={backgroundColor ? `background-color: ${backgroundColor} !important;` : ''}>
    <div class="custom-cursor"></div>

    <header class="project-header resume-header">
      <div class="header-inner">
        <a href="/" class="project-logo" data-hover>
          <span>INSIDE A HEAD</span>
          <span class="anchor-sub">STUDIO</span>
        </a>
        <nav class="nav-links">
          <a href="/" class="nav-link" data-hover>Studio</a>
          <a href="/logbook" class="nav-link" data-hover>Logbook</a>
          <a href="/resume" class="nav-link" data-hover>Resume</a>
        </nav>
        <!-- Mobile Hamburger Button -->
        <button class="hamburger-btn" aria-label="Toggle menu">
          <div class="hamburger-box">
            <div class="hamburger-line"></div>
            <div class="hamburger-line"></div>
            <div class="hamburger-line"></div>
          </div>
        </button>
      </div>
    </header>

    <!-- Full-Screen Hamburger Menu Overlay -->
    <div class="mobile-menu-overlay">
      <nav class="mobile-nav-links">
        <a href="/" class="mobile-nav-link">Studio</a>
        <a href="/logbook" class="mobile-nav-link">Logbook</a>
        <a href="/resume" class="mobile-nav-link">Resume</a>
      </nav>
      <div class="mobile-menu-footer">
        <div class="mobile-socials">
          <a href="https://github.com/iDarcky" target="_blank" rel="noreferrer">GITHUB</a>
          <a href="https://www.linkedin.com/in/danielnmaghis/" target="_blank" rel="noreferrer">LINKEDIN</a>
        </div>
      </div>
    </div>

    <!-- The actual content injected here -->
    <slot />

    <Footer />

    <script is:inline src="/project.js"></script>
  </body>
</html>
