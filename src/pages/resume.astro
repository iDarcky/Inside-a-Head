---
export const prerender = false;
import MagazineLayout from '../layouts/MagazineLayout.astro';
import { sanityClient } from '../utils/sanity';

interface ContactLink { label: string; url: string; icon?: string; }
interface Role { company: string; title: string; start?: string; end?: string; location?: string; bullets?: string[]; stack?: string[]; }
interface ProjectItem { name: string; description?: string; url?: string; }
interface Education { school: string; degree: string; start?: string; end?: string; }
interface SkillGroup { group: string; items: string[]; }
interface LangItem { name: string; level?: string; }

interface ResumeDoc {
  fullName?: string;
  headline?: string;
  summary?: string;
  location?: string;
  contactLinks?: ContactLink[];
  roles?: Role[];
  projects?: ProjectItem[];
  education?: Education[];
  skills?: SkillGroup[];
  languages?: LangItem[];
  pdfUrl?: string;
}

let resume: ResumeDoc | null = null;

try {
  resume = await sanityClient.fetch(`*[_type == "resume"][0]`);
} catch (error) {
  console.error('Failed to fetch resume:', error);
}

const FALLBACK: ResumeDoc = {
  fullName: 'Daniel N. Maghiș',
  headline: 'Product Manager',
  summary: "Product Manager with 4+ years of enterprise SaaS experience. At ATOSS Software AG I drove product discovery, roadmapping, and cross-functional delivery for workforce management solutions. Also shipped a full-stack personal project (The Retro Circuit) from zero to MVP in 3 months as sole PM.",
  location: 'Timișoara',
  contactLinks: [
    { label: 'Email Me', url: 'mailto:maghisdaniel@gmail.com', icon: 'mail' },
  ],
  roles: [
    {
      company: 'ATOSS Software AG',
      title: 'Junior Technical Product Manager',
      start: '05/2021',
      end: '01/2025',
      location: 'Timișoara · Full-time',
      bullets: [
        'Owned end-to-end product lifecycle for enterprise workforce management features across 5+ major releases.',
        'Partnered with engineering and UX to define specs and acceptance criteria, reducing story-cycle time.',
        'Built and maintained roadmaps in Jira/Confluence, aligning engineering, sales, and customer success priorities.',
        'Ran user interviews and requirement workshops with enterprise clients, translating insights into actionable epics.',
      ],
    },
    {
      company: 'Scripture Union Romania',
      title: 'Assistant Manager',
      start: '01/2016',
      end: '01/2018',
      location: 'Timișoara · Part-time',
      bullets: [
        'Led cross-functional volunteer teams of 20+ people across social and educational programs for 100+ youth.',
        'Organized 3 international youth camps per year, owning full logistics and stakeholder communication.',
      ],
    },
  ],
  projects: [
    {
      name: 'The Retro Circuit',
      url: 'https://theretrocircuit.com/',
      description: 'Founder & Sole Developer · 2024 · Specialized comparison engine for retro gaming hardware. Shipped from zero to MVP in 3 months using AI-assisted development on Next.js 16, Supabase, and Vercel.',
    },
  ],
  education: [
    { school: 'Universitatea de Vest Timișoara', degree: 'Master of Business Management', start: '2019', end: '2021' },
    { school: 'Universitatea de Vest Timișoara', degree: 'Bachelor of Business Management', start: '2016', end: '2019' },
  ],
  skills: [
    { group: 'Product', items: ['Roadmapping', 'Product Discovery', 'User Story Writing', 'OKRs', 'A/B Testing', 'Agile/Scrum', 'Zero-to-One Delivery'] },
    { group: 'Technical', items: ['AI-Assisted Development', 'Relational DB Modeling', 'Architecture Strategy', 'Next.js / React', 'Supabase', 'Vercel'] },
  ],
  languages: [
    { name: 'Romanian', level: 'Native' },
    { name: 'English', level: 'Fluent' },
    { name: 'German', level: 'Basic' },
  ],
  pdfUrl: '/daniel-n-maghis-resume.pdf',
};

const data: ResumeDoc = {
  ...FALLBACK,
  ...(resume || {}),
};

if (!data.contactLinks || data.contactLinks.length === 0) data.contactLinks = FALLBACK.contactLinks;
if (!data.roles || data.roles.length === 0) data.roles = FALLBACK.roles;
if (!data.projects || data.projects.length === 0) data.projects = FALLBACK.projects;
if (!data.education || data.education.length === 0) data.education = FALLBACK.education;
if (!data.skills || data.skills.length === 0) data.skills = FALLBACK.skills;
if (!data.languages || data.languages.length === 0) data.languages = FALLBACK.languages;
---

<MagazineLayout title={`Resume | ${data.fullName}`} description={data.summary} ogType="profile">
  <style>
    .resume-container { max-width: 800px; margin: 0 auto; padding: 120px 1.5rem 8rem 1.5rem; }
    .hero-section { text-align: center; margin-bottom: 5rem; }
    .hero-section h1 { font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 700; letter-spacing: -0.04em; margin-bottom: 0.5rem; line-height: 1.1; }
    .hero-section h2 { font-size: 1.25rem; color: var(--accents-5); font-weight: 400; margin-bottom: 2rem; }
    .hero-section p { max-width: 600px; margin: 0 auto 2.5rem auto; color: var(--accents-6); line-height: 1.6; }
    .contact-links { display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; margin-bottom: 2rem; }
    .contact-links a { display: flex; align-items: center; gap: 0.5rem; font-weight: 600; color: var(--foreground); text-decoration: none; font-size: 0.875rem; letter-spacing: 0.05em; text-transform: uppercase; transition: color 0.2s ease; }
    .contact-links a:hover { color: var(--accents-5); }
    .social-links { display: flex; justify-content: center; gap: 1.5rem; font-family: 'Geist Mono', monospace; font-size: 0.875rem; color: var(--accents-5); }
    .social-links a { color: inherit; text-decoration: none; transition: color 0.2s ease; }
    .social-links a:hover { color: var(--foreground); }

    .resume-section { margin-bottom: 5rem; }
    .resume-section-title { font-size: 1.5rem; font-weight: 600; margin-bottom: 2.5rem; border-bottom: 1px solid var(--accents-2); padding-bottom: 1rem; letter-spacing: -0.02em; }
    .resume-item { display: grid; grid-template-columns: 1fr; gap: 1rem; margin-bottom: 3rem; }
    @media (min-width: 768px) { .resume-item { grid-template-columns: 200px 1fr; gap: 2rem; } }
    .resume-date { color: var(--accents-5); font-family: 'Geist Mono', monospace; font-size: 0.9rem; padding-top: 0.25rem; }
    .resume-content h4 { font-size: 1.25rem; font-weight: 600; margin: 0 0 0.5rem 0; color: var(--foreground); }
    .resume-content .meta { color: var(--foreground); font-weight: 500; margin: 0 0 1.25rem 0; font-size: 1rem; }
    .resume-content .meta span { color: var(--accents-5); font-weight: 400; }
    .resume-content ul { list-style: none; padding: 0; margin: 0; color: var(--accents-6); line-height: 1.6; }
    .resume-content li { margin-bottom: 0.75rem; display: flex; }
    .resume-content li::before { content: "—"; color: var(--accents-4); margin-right: 0.75rem; flex-shrink: 0; }
    .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }
    .tag { font-size: 0.75rem; font-family: 'Geist Mono', monospace; padding: 0.25rem 0.5rem; background: var(--accents-1); border: 1px solid var(--accents-2); border-radius: 4px; color: var(--foreground); }
    .skills-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
    @media (min-width: 768px) { .skills-grid { grid-template-columns: 1fr 1fr; gap: 3rem; } }
    .skill-category h4 { font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accents-5); margin-bottom: 0.75rem; }
    .skill-category p { line-height: 1.6; color: var(--foreground); margin: 0; }
    .languages-list { list-style: none; padding: 0; margin: 0; }
    .languages-list li { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid var(--accents-1); }
    .languages-list li span:last-child { color: var(--accents-5); }
  </style>

  <main>
    <div class="resume-container">
      <section class="hero-section">
        <h1>{data.fullName}</h1>
        <h2>{data.headline}</h2>
        {data.summary && <p>{data.summary}</p>}

        <div class="contact-links">
          {data.contactLinks!.map((c: ContactLink) => (
            <a href={c.url} target={c.url.startsWith('http') ? '_blank' : undefined} rel={c.url.startsWith('http') ? 'noreferrer' : undefined}>
              {c.icon && <i data-lucide={c.icon} style="width: 18px; height: 18px;"></i>}
              {c.label}
            </a>
          ))}
          {data.pdfUrl && (
            <a href={data.pdfUrl} target="_blank" rel="noopener noreferrer">
              <i data-lucide="download" style="width: 18px; height: 18px;"></i> Download PDF
            </a>
          )}
        </div>

        {data.location && (
          <div class="social-links">
            <span>{data.location}</span>
          </div>
        )}
      </section>

      {data.roles && data.roles.length > 0 && (
        <section class="resume-section">
          <h3 class="resume-section-title">Professional Journey</h3>
          {data.roles.map((role: Role) => (
            <div class="resume-item">
              <div class="resume-date">{role.start} – {role.end}</div>
              <div class="resume-content">
                <h4>{role.title}</h4>
                <p class="meta">{role.company} {role.location && <span>&bull; {role.location}</span>}</p>
                {role.bullets && role.bullets.length > 0 && (
                  <ul>
                    {role.bullets.map((b: string) => <li>{b}</li>)}
                  </ul>
                )}
                {role.stack && role.stack.length > 0 && (
                  <div class="tags">
                    {role.stack.map((t: string) => <span class="tag">{t}</span>)}
                  </div>
                )}
              </div>
            </div>
          ))}
        </section>
      )}

      {data.projects && data.projects.length > 0 && (
        <section class="resume-section">
          <h3 class="resume-section-title">Projects</h3>
          {data.projects.map((p: ProjectItem) => (
            <div class="resume-item">
              <div class="resume-date"></div>
              <div class="resume-content">
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 0.5rem;">
                  <h4 style="margin: 0;">{p.name}</h4>
                  {p.url && (
                    <a href={p.url} target="_blank" rel="noreferrer" style="font-family: 'Geist Mono', monospace; font-size: 0.85rem; color: var(--accents-5); text-decoration: none; display: flex; align-items: center; gap: 4px;">
                      {p.url.replace(/^https?:\/\//, '').replace(/\/$/, '')} <i data-lucide="external-link" style="width: 12px; height: 12px;"></i>
                    </a>
                  )}
                </div>
                {p.description && <p style="color: var(--accents-6); line-height: 1.6;">{p.description}</p>}
              </div>
            </div>
          ))}
        </section>
      )}

      {data.education && data.education.length > 0 && (
        <section class="resume-section">
          <h3 class="resume-section-title">Education</h3>
          {data.education.map((e: Education) => (
            <div class="resume-item">
              <div class="resume-date">{e.start} – {e.end}</div>
              <div class="resume-content">
                <h4>{e.degree}</h4>
                <p class="meta">{e.school}</p>
              </div>
            </div>
          ))}
        </section>
      )}

      {(data.skills && data.skills.length > 0) && (
        <section class="resume-section">
          <h3 class="resume-section-title">Skillset</h3>
          <div class="skills-grid">
            {data.skills.map((s: SkillGroup) => (
              <div class="skill-category">
                <h4>{s.group}</h4>
                <p>{(s.items || []).join(', ')}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {data.languages && data.languages.length > 0 && (
        <section class="resume-section">
          <h3 class="resume-section-title">Languages</h3>
          <ul class="languages-list">
            {data.languages.map((l: LangItem) => (
              <li><span>{l.name}</span><span>{l.level}</span></li>
            ))}
          </ul>
        </section>
      )}

    </div>
  </main>
</MagazineLayout>
