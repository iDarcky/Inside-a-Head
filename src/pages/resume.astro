---
import ResumeLayout from '../layouts/ResumeLayout.astro';
---

<ResumeLayout title="Resume">
  <main class="resume-page" style="max-width: 900px; margin: 0 auto; padding: 60px 24px; color: var(--foreground); font-family: 'Geist Sans', sans-serif;">

    <!-- Hero Section -->
    <header style="display: flex; flex-direction: column; align-items: center; text-align: center; margin-bottom: 64px;">
      <h1 style="font-size: clamp(3rem, 6vw, 4rem); font-weight: 800; font-family: 'Geist Mono', monospace; letter-spacing: -0.05em; line-height: 1; margin-bottom: 16px;">
        Daniel N. Maghiș
      </h1>
      <h2 style="font-size: 1.5rem; font-weight: 500; color: var(--accents-5); margin-bottom: 24px;">
        Product Manager
      </h2>
      <p style="max-width: 600px; font-size: 1.125rem; line-height: 1.6; color: var(--accents-6); margin-bottom: 32px;">
        Product Manager with 4+ years of enterprise SaaS experience. At ATOSS Software AG I drove product discovery, roadmapping, and cross-functional delivery for workforce management solutions. Also shipped a full-stack personal project (The Retro Circuit) from zero to MVP in 3 months as sole PM.
      </p>

      <div style="display: flex; flex-wrap: wrap; gap: 16px; justify-content: center;">
        <a href="mailto:maghisdaniel@gmail.com" class="button button-massive ds-cta" style="font-size: 1rem; padding: 12px 24px; border: 1px solid var(--foreground); background: transparent; color: var(--foreground); text-decoration: none; display: flex; align-items: center; gap: 8px;">
          <i data-lucide="mail" style="width: 18px; height: 18px;"></i> Email Me
        </a>
        <a href="/resume.pdf" class="button button-massive ds-cta" style="font-size: 1rem; padding: 12px 24px; background: var(--foreground); color: var(--background); text-decoration: none; display: flex; align-items: center; gap: 8px;">
          <i data-lucide="download" style="width: 18px; height: 18px;"></i> Download Resume
        </a>
      </div>

      <div style="display: flex; gap: 24px; margin-top: 32px; font-size: 0.875rem; font-family: 'Geist Mono', monospace; color: var(--accents-5);">
        <a href="https://linkedin.com/in/danielnmaghis" target="_blank" rel="noreferrer" style="color: inherit; text-decoration: none; display: flex; align-items: center; gap: 4px;">
          <i data-lucide="linkedin" style="width: 16px; height: 16px;"></i> LinkedIn
        </a>
        <span style="display: flex; align-items: center; gap: 4px;">
          <i data-lucide="map-pin" style="width: 16px; height: 16px;"></i> Timișoara
        </span>
        <span style="display: flex; align-items: center; gap: 4px;">
          <i data-lucide="phone" style="width: 16px; height: 16px;"></i> 0735646723
        </span>
      </div>
    </header>

    <div style="display: grid; grid-template-columns: 1fr; gap: 64px; border-top: 1px solid var(--accents-2); padding-top: 64px;">

      <!-- Work Experience -->
      <section>
        <h3 style="font-size: 1.5rem; font-weight: 700; font-family: 'Geist Mono', monospace; margin-bottom: 32px; letter-spacing: -0.02em;">My Work Experience</h3>

        <div style="display: flex; flex-direction: column; gap: 40px;">
          <!-- Job 1 -->
          <div style="border-left: 2px solid var(--accents-2); padding-left: 24px; position: relative;">
            <div style="position: absolute; left: -6px; top: 0; width: 10px; height: 10px; background: var(--foreground); border-radius: 50%;"></div>
            <div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 8px; margin-bottom: 8px;">
              <h4 style="font-size: 1.25rem; font-weight: 600;">Junior Technical Product Manager</h4>
              <span style="font-size: 0.875rem; color: var(--accents-5); font-family: 'Geist Mono', monospace;">05/2021 - 01/2025</span>
            </div>
            <p style="font-size: 1rem; color: var(--accents-5); font-weight: 500; margin-bottom: 16px;">ATOSS Software AG • Timișoara • Full-time</p>
            <ul style="list-style-type: none; padding-left: 0; display: flex; flex-direction: column; gap: 12px; color: var(--accents-6); line-height: 1.6;">
              <li style="display: flex; gap: 12px;"><span style="color: var(--accents-4);">—</span> Owned end-to-end product lifecycle for enterprise workforce management features across 5+ major releases.</li>
              <li style="display: flex; gap: 12px;"><span style="color: var(--accents-4);">—</span> Partnered with engineering and UX to define specs and acceptance criteria, reducing story-cycle time.</li>
              <li style="display: flex; gap: 12px;"><span style="color: var(--accents-4);">—</span> Built and maintained roadmaps in Jira/Confluence, aligning engineering, sales, and customer success priorities.</li>
              <li style="display: flex; gap: 12px;"><span style="color: var(--accents-4);">—</span> Ran user interviews and requirement workshops with enterprise clients, translating insights into actionable epics.</li>
            </ul>
          </div>

          <!-- Job 2 -->
          <div style="border-left: 2px solid var(--accents-2); padding-left: 24px; position: relative;">
            <div style="position: absolute; left: -6px; top: 0; width: 10px; height: 10px; background: var(--accents-4); border-radius: 50%;"></div>
            <div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 8px; margin-bottom: 8px;">
              <h4 style="font-size: 1.25rem; font-weight: 600;">Assistant Manager</h4>
              <span style="font-size: 0.875rem; color: var(--accents-5); font-family: 'Geist Mono', monospace;">01/2016 - 01/2018</span>
            </div>
            <p style="font-size: 1rem; color: var(--accents-5); font-weight: 500; margin-bottom: 16px;">Scripture Union Romania • Timișoara • Part-time</p>
            <ul style="list-style-type: none; padding-left: 0; display: flex; flex-direction: column; gap: 12px; color: var(--accents-6); line-height: 1.6;">
              <li style="display: flex; gap: 12px;"><span style="color: var(--accents-4);">—</span> Led cross-functional volunteer teams of 20+ people across social and educational programs for 100+ youth.</li>
              <li style="display: flex; gap: 12px;"><span style="color: var(--accents-4);">—</span> Organized 3 international youth camps per year, owning full logistics and stakeholder communication.</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Projects -->
      <section>
        <h3 style="font-size: 1.5rem; font-weight: 700; font-family: 'Geist Mono', monospace; margin-bottom: 32px; letter-spacing: -0.02em;">Projects</h3>

        <div style="background: var(--accents-1); border: 1px solid var(--accents-2); padding: 32px; border-radius: 8px;">
          <div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 8px; margin-bottom: 16px;">
            <h4 style="font-size: 1.25rem; font-weight: 600;">The Retro Circuit</h4>
            <a href="https://theretrocircuit.com/" target="_blank" rel="noreferrer" style="font-size: 0.875rem; font-family: 'Geist Mono', monospace; color: var(--foreground); display: flex; align-items: center; gap: 4px;">
              theretrocircuit.com <i data-lucide="external-link" style="width: 14px; height: 14px;"></i>
            </a>
          </div>

          <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px;">
            {['Next.js', 'Supabase', 'SQL', 'Resend', 'Jira'].map(tech => (
              <span style="font-size: 0.75rem; font-family: 'Geist Mono', monospace; padding: 4px 8px; background: var(--accents-2); border-radius: 4px; color: var(--foreground);">{tech}</span>
            ))}
          </div>

          <ul style="list-style-type: none; padding-left: 0; display: flex; flex-direction: column; gap: 12px; color: var(--accents-6); line-height: 1.6; font-size: 0.95rem;">
            <li style="display: flex; gap: 12px;"><span style="color: var(--accents-4);">—</span> Identified market fragmentation in retro gaming hardware: consumers lacked a reliable way to compare complex device variants. Designed and shipped a specialized comparison engine from zero to MVP in 3 months.</li>
            <li style="display: flex; gap: 12px;"><span style="color: var(--accents-4);">—</span> Leveraged Google AI Studio as an engineering counterpart — writing precise specs, defining architecture constraints, and managing a CI/CD pipeline (Next.js 16, Supabase/PostgreSQL, Vercel) without writing code natively.</li>
            <li style="display: flex; gap: 12px;"><span style="color: var(--accents-4);">—</span> Architected a relational data schema (Manufacturers → Consoles → Variants) to eliminate 'signal noise' — enabling SKU-level comparisons rather than generic product aggregations.</li>
            <li style="display: flex; gap: 12px;"><span style="color: var(--accents-4);">—</span> Built a restricted Admin Command Center with RBAC and validation rules, enabling non-technical content management and scaling the product catalog without database intervention.</li>
          </ul>
        </div>
      </section>

      <!-- Two Column Layout for Skills & Education -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 48px;">

        <!-- Skills Section -->
        <section>
          <h3 style="font-size: 1.5rem; font-weight: 700; font-family: 'Geist Mono', monospace; margin-bottom: 24px; letter-spacing: -0.02em;">Skills</h3>
          <div style="display: flex; flex-direction: column; gap: 24px;">
            <div>
              <h4 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accents-5); margin-bottom: 12px;">Product</h4>
              <p style="line-height: 1.6; color: var(--foreground);">Roadmapping, Product Discovery, User Story Writing, OKRs, A/B Testing, Agile/Scrum, Zero-to-One Delivery</p>
            </div>
            <div>
              <h4 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accents-5); margin-bottom: 12px;">Technical</h4>
              <p style="line-height: 1.6; color: var(--foreground);">AI-Assisted Development, Relational DB Modeling, Architecture Strategy, Next.js / React, Supabase, Vercel</p>
            </div>
            <div>
              <h4 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accents-5); margin-bottom: 12px;">Languages</h4>
              <p style="line-height: 1.6; color: var(--foreground);">Romanian (Native), English (Fluent), German (Basic)</p>
            </div>
          </div>
        </section>

        <!-- Education & Certifications -->
        <div style="display: flex; flex-direction: column; gap: 48px;">
          <section>
            <h3 style="font-size: 1.5rem; font-weight: 700; font-family: 'Geist Mono', monospace; margin-bottom: 24px; letter-spacing: -0.02em;">Education</h3>
            <div style="margin-bottom: 16px;">
              <h4 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 8px;">Universitatea de Vest Timișoara</h4>
              <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                <span style="color: var(--accents-6);">Master of Business Management</span>
                <span style="font-size: 0.875rem; color: var(--accents-5); font-family: 'Geist Mono', monospace;">2019 - 2021</span>
              </div>
              <div style="display: flex; justify-content: space-between;">
                <span style="color: var(--accents-6);">Bachelor of Business Management</span>
                <span style="font-size: 0.875rem; color: var(--accents-5); font-family: 'Geist Mono', monospace;">2016 - 2019</span>
              </div>
            </div>
          </section>

          <section>
            <h3 style="font-size: 1.5rem; font-weight: 700; font-family: 'Geist Mono', monospace; margin-bottom: 24px; letter-spacing: -0.02em;">Certifications</h3>
            <ul style="list-style-type: none; padding-left: 0; display: flex; flex-direction: column; gap: 12px; color: var(--foreground);">
              <li style="display: flex; justify-content: space-between;">
                <strong>Product Strategy (PSC)</strong> <span style="color: var(--accents-5);">Product School</span>
              </li>
              <li style="display: flex; justify-content: space-between;">
                <strong>Product Discovery</strong> <span style="color: var(--accents-5);">Product School</span>
              </li>
              <li style="display: flex; justify-content: space-between;">
                <strong>Product Experimentation</strong> <span style="color: var(--accents-5);">Product School</span>
              </li>
              <li style="display: flex; justify-content: space-between;">
                <strong>Product-Led Growth</strong> <span style="color: var(--accents-5);">Product School</span>
              </li>
            </ul>
          </section>

          <section>
            <h3 style="font-size: 1.5rem; font-weight: 700; font-family: 'Geist Mono', monospace; margin-bottom: 24px; letter-spacing: -0.02em;">Volunteering & Leadership</h3>

            <div style="margin-bottom: 24px;">
              <h4 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 4px;">BBPT</h4>
              <p style="font-size: 1rem; margin-bottom: 4px;"><strong>Social Media Lead</strong></p>
              <p style="font-size: 0.95rem; color: var(--accents-6); line-height: 1.6;">Led social media strategy (Facebook/Instagram) and implemented software for media production and lyric projection.</p>
            </div>

            <div style="margin-bottom: 24px;">
              <h4 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 4px;">Scripture Union</h4>
              <p style="font-size: 1rem; margin-bottom: 4px;"><strong>Team Leader & Coordinator</strong></p>
              <p style="font-size: 0.95rem; color: var(--accents-6); line-height: 1.6;">Recruited and led 20+ volunteers; coordinated international camps, youth programs, and NGO outreach initiatives.</p>
            </div>
          </section>
        </div>
      </div>

    </div>
  </main>
</ResumeLayout>