---
export const prerender = false;
import MagazineLayout from '../../layouts/MagazineLayout.astro';
import PortableText from '../../components/PortableText.astro';
import { sanityClient, urlFor } from '../../utils/sanity';
import { readingTimeFromPortableText, plainTextFromPortableText } from '../../utils/text';

const { slug } = Astro.params;
let entry: any = null;

try {
  entry = await sanityClient.fetch(`*[_type == "logbookEntry" && slug.current == $slug][0]`, { slug });
} catch (error) {
  console.error("Failed to fetch logbook entry:", error);
}

if (!entry) {
  return Astro.redirect('/404');
}

if (entry.status === 'draft') {
  return Astro.redirect('/404');
}

const readingTime = readingTimeFromPortableText(entry.body, entry.readingTime);
const description = entry.excerpt || plainTextFromPortableText(entry.body, 180) || 'A logbook entry from Inside a Head.';
const heroImageUrl = entry.heroImage ? urlFor(entry.heroImage).width(1200).url() : undefined;
---

<MagazineLayout
  title={entry.title}
  description={description}
  ogImage={heroImageUrl}
  ogType="article"
  publishedAt={entry.publishedAt}
>
  {entry.heroImage && (
    <div class="project-hero-wrapper">
      <img src={urlFor(entry.heroImage).url()} alt={entry.title} class="project-hero-img" />
    </div>
  )}

  <article class="article-layout">
    <header class="article-header">
      <span class="manifesto-kicker" style="margin-bottom: 12px;">LOGBOOK ENTRY</span>
      <h1 class="article-title">{entry.title}</h1>
      <div class="article-meta-grid">
        <div class="meta-item">
          <span class="meta-label">PUBLISHED</span>
          <span class="meta-value">{entry.publishedAt ? new Date(entry.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'N/A'}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">READING TIME</span>
          <span class="meta-value">{readingTime} MIN READ</span>
        </div>
      </div>
      {entry.tags && entry.tags.length > 0 && (
        <div style="margin-top: 1.5rem; display: flex; flex-wrap: wrap; gap: 8px;">
          {entry.tags.map((t: string) => (
            <a
              href={`/logbook/tag/${encodeURIComponent(t.toLowerCase())}`}
              data-hover
              style="font-family: var(--font-mono); font-size: 0.75rem; padding: 4px 12px; border: 1px solid var(--geist-border); border-radius: 999px; color: var(--accents-6); text-decoration: none;"
            >
              #{t}
            </a>
          ))}
        </div>
      )}
    </header>

    <section class="article-body">
      {entry.body ? <PortableText portableText={entry.body} /> : <p>No content available.</p>}
    </section>

    <footer class="magazine-footer-nav" style="justify-content: flex-end;">
      <a href="/#logbook" class="footer-nav-link" data-hover style="text-align: right;">
        <span class="nav-label">RETURN TO</span>
        Logbook
      </a>
    </footer>
  </article>
</MagazineLayout>

