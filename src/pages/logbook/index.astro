---
import MagazineLayout from '../../layouts/MagazineLayout.astro';
import { sanityClient } from '../../utils/sanity';

const logbookEntries = await sanityClient.fetch(`*[_type == "logbookEntry"] | order(publishedAt desc)`);
---

<MagazineLayout title="Logbook">
  <main class="article-layout">
    <header class="article-header">
      <h1 class="article-title" style="margin-top: 80px;">STUDIO LOG</h1>
      <p style="color: var(--accents-5); font-family: var(--font-mono); font-size: 0.9rem; margin-top: 1rem;">
        CHRONOLOGICAL FRAGMENTS & DOCUMENTATION
      </p>
    </header>

    <div class="logbook-list" style="border-top: 1px solid var(--geist-border);">
      {logbookEntries.map((entry: any) => {
        const dateStr = new Date(entry.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.');
        return (
          <a href={`/logbook/${entry.slug.current}`} class="logbook-entry" data-hover>
            <div class="logbook-date">{dateStr}</div>
            <div class="logbook-content">
              <h3 class="logbook-title-parallax">{entry.title}</h3>
            </div>
          </a>
        );
      })}
      
      {logbookEntries.length === 0 && (
        <p style="text-align: center; color: var(--accents-4); padding: 4rem 0;">
          The log is currently empty.
        </p>
      )}
    </div>

    <div style="text-align: center; margin-top: 60px;">
      <a href="/#top" class="footer-back-studio" data-hover style="display: inline-block;">&larr; Back to Studio</a>
    </div>
  </main>
</MagazineLayout>
