---
export const prerender = false;
import MagazineLayout from "../../../layouts/MagazineLayout.astro";
import { sanityClient } from "../../../utils/sanity";
import { readingTimeFromPortableText } from "../../../utils/text";

const { tag } = Astro.params;
const decodedTag = decodeURIComponent(tag ?? '');

let entries: any[] = [];

try {
  entries = await sanityClient.fetch(
    `*[_type == "logbookEntry" && (status == "published" || !defined(status)) && $tag in tags[]@->lower()]
      | order(publishedAt desc){
        title, slug, publishedAt, excerpt, tags, readingTime, body
      }`,
    { tag: decodedTag.toLowerCase() },
  );
} catch (error) {
  console.error('Failed to fetch tag entries:', error);
}

// Fallback: client filter (the @->lower() trick varies by GROQ version)
if (entries.length === 0) {
  try {
    const all = await sanityClient.fetch(
      `*[_type == "logbookEntry" && (status == "published" || !defined(status))]
        | order(publishedAt desc){
          title, slug, publishedAt, excerpt, tags, readingTime, body
        }`,
    );
    entries = all.filter((e: any) =>
      (e.tags || []).map((t: string) => t.toLowerCase()).includes(decodedTag.toLowerCase()),
    );
  } catch (error) {
    console.error('Tag fallback fetch failed:', error);
  }
}
---

<MagazineLayout
  title={`#${decodedTag} | Logbook`}
  description={`Logbook entries tagged #${decodedTag}.`}
>
  <main class="article-layout">
    <div style="height: 180px; width: 100%;"></div>

    <header class="article-header" style="margin-bottom: 3rem;">
      <p style="color: var(--accents-5); font-family: var(--font-mono); font-size: 0.8rem;">
        FILTERED BY TAG
      </p>
      <h1 class="article-title" style="margin-top: 0.5rem;">#{decodedTag}</h1>
      <p style="margin-top: 1rem;">
        <a href="/logbook" class="footer-back-studio" data-hover style="display: inline-block; margin: 0;">
          &larr; All entries
        </a>
      </p>
    </header>

    <div class="logbook-list" style="border-top: 1px solid var(--geist-border);">
      {entries.length === 0 && (
        <p style="text-align: center; color: var(--accents-4); padding: 4rem 0;">
          No entries tagged #{decodedTag} yet.
        </p>
      )}
      {entries.map((entry: any) => {
        const date = new Date(entry.publishedAt);
        const dateStr = `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
        const minutes = readingTimeFromPortableText(entry.body, entry.readingTime);
        return (
          <a href={`/logbook/${entry.slug.current}`} class="logbook-entry" data-hover>
            <div class="logbook-date">
              <div>{dateStr}</div>
              <div style="font-size: 0.75rem; color: var(--accents-4); margin-top: 4px;">{minutes} MIN READ</div>
            </div>
            <div class="logbook-content">
              <h3 class="logbook-title-parallax">{entry.title}</h3>
              {entry.excerpt && <p style="color: var(--accents-6); margin-top: 8px;">{entry.excerpt}</p>}
            </div>
          </a>
        );
      })}
    </div>
  </main>
</MagazineLayout>
