---
export const prerender = false;
import MagazineLayout from '../../layouts/MagazineLayout.astro';
import { sanityClient, urlFor } from '../../utils/sanity';

let projects: any[] = [];

try {
  projects = await sanityClient.fetch(
    `*[_type == "project"] | order(order asc){
      title, slug, role, year, stack, status, description, themeHex, tags, featured,
      homepageImage, projectUrl
    }`,
  );
} catch (error) {
  console.error('Failed to fetch projects:', error);
}

const allTags = Array.from(new Set(projects.flatMap((p) => p.tags || []))).sort();
const allYears = Array.from(new Set(projects.map((p) => p.year).filter(Boolean))).sort().reverse();
---

<MagazineLayout
  title="Projects"
  description="The full archive of builds, experiments, and shipped work from Inside a Head."
  ogType="website"
>
  <main class="projects-index-layout">
    <div style="height: 180px; width: 100%;"></div>

    <header class="article-header" style="margin-bottom: 3rem; padding: 0 5vw;">
      <p style="color: var(--accents-5); font-family: var(--font-mono); font-size: 0.8rem; letter-spacing: 0.1em;">
        PROJECT ARCHIVE — {projects.length} TOTAL
      </p>
      <h1 class="article-title" style="margin-top: 0.5rem;">PROJECTS</h1>
      <p style="color: var(--accents-6); margin-top: 1rem; max-width: 60ch;">
        Shipped products, side projects, and experiments. Some are live, some are archived, all of them taught me something.
      </p>

      {(allTags.length > 0 || allYears.length > 0) && (
        <div class="projects-filter-bar">
          <button class="filter-chip active" data-filter="all">ALL</button>
          {allYears.map((y: string) => (
            <button class="filter-chip" data-filter-year={y}>{y}</button>
          ))}
          {allTags.map((t: string) => (
            <button class="filter-chip" data-filter-tag={t}>#{t}</button>
          ))}
        </div>
      )}
    </header>

    {projects.length === 0 && (
      <p style="text-align: center; color: var(--accents-4); padding: 4rem 0;">
        No projects yet. Add one in the Studio.
      </p>
    )}

    <div class="projects-grid">
      {projects.map((p: any) => {
        const bg = p.themeHex || '#1a0f30';
        const img = p.homepageImage ? urlFor(p.homepageImage).width(800).url() : null;
        return (
          <a
            href={`/projects/${p.slug.current}`}
            class="project-card"
            style={`background-color: ${bg};`}
            data-hover
            data-year={p.year || ''}
            data-tags={(p.tags || []).join(',')}
          >
            {img && <div class="project-card-image" style={`background-image: url('${img}');`}></div>}
            <div class="project-card-meta">
              <div class="project-card-kicker">
                <span>{p.year || '—'}</span>
                {p.featured && <span class="featured-pill">FEATURED</span>}
              </div>
              <h3 class="project-card-title">{p.title}</h3>
              {p.description && (
                <p class="project-card-desc">{p.description}</p>
              )}
              <div class="project-card-footer">
                <span class="project-card-stack">{p.stack || ''}</span>
                <span class="project-card-status">{p.status || ''}</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <div style="text-align: center; margin: 4rem 0;">
      <a href="/" class="footer-back-studio" data-hover style="display: inline-block;">
        &larr; Back to Studio
      </a>
    </div>
  </main>
</MagazineLayout>

<script is:inline>
  (function () {
    const chips = document.querySelectorAll('.filter-chip');
    const cards = document.querySelectorAll('.project-card');
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.classList.remove('active'));
        chip.classList.add('active');
        const filter = chip.getAttribute('data-filter');
        const year = chip.getAttribute('data-filter-year');
        const tag = chip.getAttribute('data-filter-tag');
        cards.forEach((card) => {
          let show = true;
          if (year) show = card.getAttribute('data-year') === year;
          else if (tag) show = (card.getAttribute('data-tags') || '').split(',').map((t) => t.trim()).includes(tag);
          else if (filter === 'all') show = true;
          card.style.display = show ? '' : 'none';
        });
      });
    });
  })();
</script>

<style>
  .projects-index-layout {
    max-width: 1400px;
    margin: 0 auto;
    padding-bottom: 6rem;
  }

  .projects-filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 2rem;
  }

  .filter-chip {
    background: transparent;
    color: var(--accents-6);
    border: 1px solid var(--geist-border);
    padding: 6px 14px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    cursor: pointer;
    letter-spacing: 0.05em;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .filter-chip:hover {
    color: var(--foreground);
    border-color: var(--accents-5);
  }

  .filter-chip.active {
    background: var(--foreground);
    color: var(--background);
    border-color: var(--foreground);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    padding: 0 5vw;
  }

  @media (max-width: 1024px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .projects-grid { grid-template-columns: 1fr; }
  }

  .project-card {
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: transform 0.4s ease, border-color 0.3s ease;
    min-height: 420px;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.25);
  }

  .project-card-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    background-size: cover;
    background-position: top center;
  }

  .project-card-meta {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .project-card-kicker {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accents-5);
    letter-spacing: 0.1em;
  }

  .featured-pill {
    background: rgba(255, 255, 255, 0.12);
    padding: 2px 8px;
    border-radius: 999px;
    color: var(--foreground);
  }

  .project-card-title {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .project-card-desc {
    color: var(--accents-6);
    font-size: 0.9rem;
    line-height: 1.55;
    flex: 1;
  }

  .project-card-footer {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accents-5);
    letter-spacing: 0.05em;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 12px;
  }
</style>
