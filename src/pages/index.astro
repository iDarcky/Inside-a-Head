---
export const prerender = false;
import HomeLayout from '../layouts/HomeLayout.astro';
import Footer from '../components/Footer.astro';
import ProjectPanel from '../components/ProjectPanel.astro';
import { sanityClient, urlFor } from '../utils/sanity';

let logbookEntries: any[] = [];
let projects: any[] = [];
let siteSettings: any = null;
let museumTeasers: any[] = [];

try {
  [logbookEntries, projects, siteSettings, museumTeasers] = await Promise.all([
    sanityClient.fetch(`*[_type == "logbookEntry" && (status == "published" || !defined(status))] | order(publishedAt desc) [0..2]`),
    sanityClient.fetch(`*[_type == "project" && (featured == true || !defined(featured))] | order(order asc) [0..2]`),
    sanityClient.fetch(`*[_type == "siteSettings"][0]`),
    sanityClient.fetch(`*[_type == "museumFragment"] | order(date desc) [0..2]`),
  ]);
} catch (error) {
  console.error("Failed to fetch data from Sanity:", error);
}

const siteTitle = siteSettings?.siteTitle || "Inside a Head | Digital Studio";
const siteDescription = siteSettings?.siteDescription || "The digital studio of Daniel. Product Manager, Musician, and Builder.";
const bio = siteSettings?.bio || "hi, daniel here. welcome to inside a head. a personal studio for tech experiments and exploring aesthetic design. documenting the learning process, and making room for the personal mess.";
const ogImage = siteSettings?.ogImage ? urlFor(siteSettings.ogImage).width(1200).url() : undefined;
---

<HomeLayout title={siteTitle} description={siteDescription} projects={projects} ogImage={ogImage} showDotNav={true}>
  <section class="hero-immersive section-snap" id="top">
    <div class="hero-parallax-wrapper">
      <h1 id="hero-title" class="hero-massive-text">INSIDE A HEAD</h1>

      <div class="hero-center-cluster">
        <div class="intro-portrait"></div>
        <div class="intro-logo-overlay">
          <svg viewBox="0 0 100 100" class="iah-logo">
            <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" font-family="'Geist Mono', monospace" font-size="28" font-weight="bold" fill="currentColor" letter-spacing="-2">STUDIO</text>
          </svg>
        </div>
      </div>

      <p class="hero-copy centered-text" id="profile-bio">
        {bio}
      </p>
    </div>

    <div class="scroll-indicator-wrapper">
      <span class="scroll-indicator-text">SCROLL FOR MORE</span>
      <div class="scroll-indicator">
        <div class="scroll-indicator-line"></div>
      </div>
    </div>
  </section>

  {projects.map((project: any, index: number) => (
    <ProjectPanel project={project} index={index} />
  ))}

  <!-- View all projects CTA -->
  <section class="engine-room-section section-snap" id="all-projects-cta">
    <div class="engine-room-content">
      <div>
        <div class="bento-kicker" style="margin-bottom: 16px;">PROJECT ARCHIVE</div>
        <h2 class="engine-title">SEE THE FULL CATALOG</h2>
        <p class="engine-copy">Featured here is a curated selection. The complete archive of builds, experiments, and shipped work lives in the projects index.</p>
      </div>
      <a href="/projects" class="button button-massive ds-cta" data-hover>
        View all projects <i data-lucide="arrow-right" style="margin-left: 16px; width: 24px; height: 24px;"></i>
      </a>
    </div>
  </section>

  <!-- The Logbook -->
  <section class="logbook-cinematic section-snap" id="logbook">
    <div class="logbook-header-wrapper">
      <h2 class="logbook-huge-title">LOGBOOK</h2>
    </div>
    <div id="logbook-list" class="logbook-list">
      {logbookEntries.map((entry: any) => {
        const date = new Date(entry.publishedAt);
        const dateStr = `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
        return (
          <a href={`/logbook/${entry.slug.current}`} class="logbook-entry" data-hover>
            <div class="logbook-date">{dateStr}</div>
            <div class="logbook-content">
              <h3 class="logbook-title-parallax">{entry.title}</h3>
              {entry.excerpt && <p class="logbook-excerpt">{entry.excerpt}</p>}
            </div>
          </a>
        );
      })}
    </div>
    <div class="logbook-footer" style="margin-top: 4vw; text-align: right;">
      <a href="/logbook" class="button button-massive" data-hover style="padding: 16px 32px; font-size: 1rem;">View Full Logbook →</a>
    </div>
  </section>

  <!-- Museum of My Mess teaser -->
  <section class="engine-room-section section-snap" id="museum-teaser">
    <div class="engine-room-content">
      <div>
        <div class="bento-kicker" style="margin-bottom: 16px;">PERSONAL ARCHIVE</div>
        <h2 class="engine-title">MUSEUM OF MY MESS</h2>
        <p class="engine-copy">Photos, quotes, books, gear, athletics, what I'm listening to. The personal stuff that doesn't fit anywhere else.</p>
        {museumTeasers.length > 0 && (
          <ul class="museum-teaser-list">
            {museumTeasers.map((f: any) => {
              const dateStr = f.date ? new Date(f.date).toISOString().slice(0, 10).replace(/-/g, '.') : '';
              return (
                <li>
                  <span class="museum-teaser-date">{dateStr}</span>
                  <span class="museum-teaser-kind">{(f.kind || 'note').toUpperCase()}</span>
                  <span class="museum-teaser-title">{f.title || '—'}</span>
                </li>
              );
            })}
          </ul>
        )}
      </div>
      <a href="/museum" class="button button-massive ds-cta" data-hover>
        Enter the museum <i data-lucide="arrow-right" style="margin-left: 16px; width: 24px; height: 24px;"></i>
      </a>
    </div>
  </section>

  <Footer className="section-snap" variant="massive" />
</HomeLayout>

<style>
  .logbook-excerpt {
    color: var(--accents-5);
    font-size: 0.95rem;
    line-height: 1.5;
    margin-top: 8px;
    max-width: 60ch;
  }

  .museum-teaser-list {
    list-style: none;
    padding: 0;
    margin: 32px 0 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .museum-teaser-list li {
    display: grid;
    grid-template-columns: 100px 80px 1fr;
    gap: 16px;
    color: var(--accents-6);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 12px;
  }

  .museum-teaser-kind {
    color: var(--accents-4);
    letter-spacing: 0.1em;
  }

  .museum-teaser-title {
    color: var(--foreground);
  }

  @media (max-width: 640px) {
    .museum-teaser-list li {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }
</style>
