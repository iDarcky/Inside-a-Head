---
export const prerender = false;
import HomeLayout from '../layouts/HomeLayout.astro';
import Footer from '../components/Footer.astro';
import { sanityClient } from '../utils/sanity';

const logbookEntries = await sanityClient.fetch(`*[_type == "logbookEntry"] | order(publishedAt desc) [0..2]`);
---

<HomeLayout title="Inside a Head | Digital Studio">
  <section class="hero-immersive section-snap" id="top">
    <div class="hero-parallax-wrapper">
      <h1 id="hero-title" class="hero-massive-text">INSIDE A HEAD</h1>

      <div class="hero-center-cluster">
        <div class="intro-portrait"></div>
        <div class="intro-logo-overlay">
          <svg viewBox="0 0 100 100" class="iah-logo">
            <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" font-family="'Geist Mono', monospace" font-size="28" font-weight="bold" fill="currentColor" letter-spacing="-2">STUDIO</text>
          </svg>
        </div>
      </div>

      <p class="hero-copy centered-text" id="profile-bio">
        hi, daniel here. welcome to inside a head. a personal studio for tech experiments and exploring aesthetic design. documenting the learning process, and making room for the personal mess.
      </p>
    </div>

    <div class="scroll-indicator-wrapper">
      <span class="scroll-indicator-text">SCROLL FOR MORE</span>
      <div class="scroll-indicator">
        <div class="scroll-indicator-line"></div>
      </div>
    </div>
  </section>

  <div id="studio-anchor"></div>

  <!-- The Design System (The Engine Room) -->
  <section class="engine-room-section section-snap" id="design-system">
    <div class="engine-room-content">
      <div>
        <h2 class="engine-title">SYSTEM ARCHITECTURE</h2>
        <p class="engine-copy">Powered by Geist UI. Explore the foundational principles, typography, and semantic components that power every app in the studio.</p>
      </div>
      <a href="https://design-system-dm.vercel.app/" class="button button-massive ds-cta" target="_blank" rel="noreferrer" data-hover>
        Explore <i data-lucide="arrow-right" style="margin-left: 16px; width: 24px; height: 24px;"></i>
      </a>
    </div>
  </section>

  <!-- The Logbook -->
  <section class="logbook-cinematic section-snap" id="logbook">
    <div class="logbook-header-wrapper">
      <h2 class="logbook-huge-title">LOGBOOK</h2>
    </div>
    <div id="logbook-list" class="logbook-list">
      {logbookEntries.map((entry: any) => {
        const date = new Date(entry.publishedAt);
        const dateStr = `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
        return (
          <a href={`/logbook/${entry.slug.current}`} class="logbook-item" data-hover>
            <span class="logbook-date">{dateStr}</span>
            <span class="logbook-title">{entry.title}</span>
          </a>
        );
      })}
    </div>
<div class="logbook-footer" style="margin-top: 4vw; text-align: right;">
      <a href="/logbook" class="button button-massive" data-hover style="padding: 16px 32px; font-size: 1rem;">View Full Logbook →</a>
    </div>
  </section>

  <!-- The Shelf Part 1: Build Metrics & Status -->
  <section class="bento-section section-snap" id="shelf-builds">
    <div class="bento-wrapper">
      <div class="logbook-header-wrapper">
        <h2 class="logbook-huge-title bento-title-parallax">MUSEUM OF MY MESS</h2>
      </div>
      <div class="bento-grid bento-grid-builds">
        <!-- Tile: Clock -->
        <div class="bento-tile bento-clock">
          <div class="bento-kicker">LOCAL TIME</div>
          <div class="geist-wrapper">
            <span id="geist-time" class="geist-time">00:00</span>
            <span id="geist-seconds" class="geist-seconds">00</span>
          </div>
          <div class="clock-location">BUCHAREST, RO</div>
        </div>

        <!-- Tile: Extra -->
        <!-- Removed empty placeholder -->

        <!-- Tile: Book (Named Area: book) -->
        <div class="bento-tile bento-reading" id="bento-reading"></div>

        <!-- Tile: GitHub (Named Area: gh) -->
        <div class="bento-tile bento-github">
          <div class="github-header">
            <div class="bento-kicker">BUILD METRICS</div>
            <div class="gh-counter" id="gh-total-count">... contributions</div>
          </div>
          <div class="github-container">
            <div class="gh-labels-y"><span>Mon</span><span>Wed</span><span>Fri</span></div>
            <div class="github-matrix"></div>
          </div>
          <div class="github-footer">
            <div class="github-meta"><span>github.com/iDarcky</span><i data-lucide="github" style="width: 14px;"></i></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Shelf Part 2: Gear & Media -->
  <section class="bento-section section-snap" id="shelf-media">
    <div class="bento-wrapper">
      <div class="logbook-header-wrapper">
        <div class="bento-kicker" style="color: var(--accents-5); letter-spacing: 0.3em; margin-bottom: 16px;">THE GEAR // THE MESS</div>
        <h2 class="logbook-huge-title bento-title-parallax" style="font-size: clamp(2rem, 5vw, 4rem); color: var(--accents-4);">COLLECTED FRAGMENTS</h2>
      </div>
      <div class="bento-grid bento-grid-media">
        <!-- Tile: Spotify (Named Area: audio) -->
        <div class="bento-tile bento-audio" style="padding: 0;">
          <iframe src="https://open.spotify.com/embed/track/5lNmaZfu3SQMuzl1hH2wzA?utm_source=generator" style="border-radius:16px; border: none; width: 100%; height: 100%;" frameBorder="0" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
        </div>

        <!-- Tile: Gear (Named Area: shoe) -->
        <div class="bento-tile bento-shoe">
          <div class="bento-kicker">CURRENT GEAR</div>
          <!-- We use absolute public URLs for static assets that we ported -->
          <img src="https://cdn1.npcdn.net/images/c66082ec8dffeee531fb002baa744f91_1758184573.webp?md5id=2169a2cc59e83ed5c094702f589fdd1d&new_width=1000&new_height=1000&w=1755845547&from=png&type=9" class="shoe-img" alt="Adidas Evo SL" />
          <div class="shoe-name">ADIDAS EVO SL</div>
        </div>

        <!-- Tile: Athletics (Named Area: athletics) -->
        <div class="bento-tile bento-athletics">
          <div class="bento-kicker">ATHLETICS</div>
          <div class="athletics-data">
            <div class="ath-row"><span class="ath-label">HALF MARATHON</span><span class="ath-value">1:38:42</span></div>
            <div class="ath-row"><span class="ath-label">5K PR</span><span class="ath-value">20:15</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer className="section-snap" variant="massive" />
</HomeLayout>
